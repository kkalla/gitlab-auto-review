# GitLab 인스턴스 베이스 URL (끝에 슬래시 없이)
GITLAB_URL=https://gitlab.example.com

# GitLab Personal Access Token (api 스코프 필요)
GITLAB_TOKEN=glpat-replace-me

# GitLab Webhook 등록 시 사용한 Secret Token
# (webhook 모드 = webhook_server.py 에서만 사용. Slack 봇 모드에서는 불필요.)
WEBHOOK_SECRET=change-me-to-a-long-random-string

# 자동 리뷰 트리거 대상 리뷰어 username (webhook 모드 필터 + 실패 알림 @멘션 대상)
REVIEWER_USERNAME=max

# ── Claude 인증 (필수) ─────────────────────────────────────────────────────
# 컨테이너의 claude는 호스트 macOS Keychain을 못 읽으므로 ~/.claude 마운트만으로는
# 인증이 안 된다("Not logged in"). 호스트에서 `claude setup-token`을 한 번 실행해
# (브라우저 OAuth) 출력된 장기 토큰(구독 기반, 약 1년 유효)을 여기에 붙여넣는다.
# review_runner가 claude -p 실행 시 이 토큰으로 인증한다. ANTHROPIC_API_KEY 불필요.
#   주의: full Bash 허용(ALLOWED_TOOLS) 상태에선 prompt injection 시 이 토큰이
#   claude 서브프로세스 env에서 유출될 수 있다 — git만 허용으로 좁히면 표면이 준다.
CLAUDE_CODE_OAUTH_TOKEN=

# ── Slack 봇 모드 (slack_bot.py) ──────────────────────────────────────────
# Slack App 생성 후 발급. 자세한 설정은 SLACK_SETUP.md 참고.
# Bot User OAuth Token (xoxb-…) — chat:write, app_mentions:read,
#   users:read, users:read.email, im:write 스코프 필요.
SLACK_BOT_TOKEN=xoxb-replace-me
# App-Level Token (xapp-…) — connections:write 스코프. Socket Mode 전용.
SLACK_APP_TOKEN=xapp-replace-me
# 리뷰 완료/실패 시 DM 받을 "나"의 Slack member ID (U…). 프로필 → 더보기 →
#   "멤버 ID 복사"로 확인. 비우면 리뷰어 DM은 생략(assignee DM은 이메일 매핑).
REVIEWER_SLACK_ID=U000000000

# MR push 증분 자동 리뷰 폴링 간격(초). GitLab Slack 알림은 push(새 커밋)를 채널에
# 안 띄우므로, 봇이 직접 reviewer=REVIEWER_USERNAME 열린 MR의 source SHA를 이 주기로
# 확인해 새 push를 자동 리뷰한다(증분은 review_runner의 reviewed-sha 마커가 처리).
# 0이면 폴러 비활성화(@멘션·채널 알림만). 기본 300(5분).
POLL_INTERVAL_SEC=300

# 로그 레벨 (INFO 기본 / DEBUG로 올리면 git·claude stderr 자세히 노출 — 디버깅용)
LOG_LEVEL=INFO

# ── Notion 현황 조회 (/task-status·/project-status, 선택) ───────────────────
# Notion internal integration secret (https://www.notion.so/my-integrations).
# 대상 DB(Tasks·Projects 둘 다)에 통합을 연결(DB 우상단 ⋯ → 연결 → 통합 선택)
# 해야 조회된다. Assignee/Owner 이름 표시엔 통합 capability "사용자 정보 읽기" 필요.
# 비우면 두 커맨드가 안내 문구만 답한다(봇 부팅엔 영향 없음).
NOTION_TOKEN=
# /task-status가 조회할 Notion Tasks DB ID (기본: 제1연구센터 Tasks)
NOTION_TASKS_DB_ID=2e19f036b307806c9a2cf0f77de82190
# /project-status와 티어 판정이 조회할 Notion Projects DB ID
# (기본: 제1연구센터 Projects — Tasks의 Project relation이 가리키는 DB)
NOTION_PROJECTS_DB_ID=2e19f036b30780f1bd47cc2d6e3af1f9
